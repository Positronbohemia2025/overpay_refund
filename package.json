{
  "name": "overpay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Loan-analysis landing page for a Moldovan microfinance contract-analysis service.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && node scripts/build-static.mjs",
    "preview": "vite preview",
    "test": "vitest run tests/unit tests/a11y",
    "test:watch": "vitest tests/unit tests/a11y",
    "test:e2e": "playwright test",
    "lint": "eslint . && stylelint \"src/**/*.css\"",
    "lint:content": "vitest run tests/content",
    "lint:release": "vitest run tests/release",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "i18next": "^24.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "stylelint": "^16.13.0",
    "stylelint-config-standard": "^36.0.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^3.0.0",
    "vitest-axe": "^0.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
