# Base URL of the analysis intake service (contracts/upload-intake.md). TLS required.
VITE_INTAKE_BASE_URL=https://intake.example.md

# Optional. Defaults to VITE_INTAKE_BASE_URL when unset (Phase 3 newsletter).
# VITE_NEWSLETTER_BASE_URL=https://intake.example.md

# Optional override of the 15 MB default max upload size, in bytes.
# VITE_MAX_UPLOAD_BYTES=15728640
